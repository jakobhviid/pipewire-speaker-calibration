class Pwtune < Formula
  desc "Measure any speaker with any mic and build a PipeWire EQ profile"
  homepage "https://github.com/jakobhviid/pwtune"
  version "@VERSION@"
  license "MIT"

  # Prebuilt x86_64 Linux bottle so `brew install` pours it (no C compiler);
  # aarch64 falls back to the url+install path below.
  bottle do
    root_url "https://github.com/jakobhviid/pwtune/releases/download/v@VERSION@"
    sha256 cellar: :any_skip_relocation, x86_64_linux: "@BOTTLE_SHA@"
  end

  on_linux do
    on_intel do
      url "https://github.com/jakobhviid/pwtune/releases/download/v@VERSION@/pwtune-x86_64-unknown-linux-musl.tar.gz"
      sha256 "@X86_SHA@"
    end
    on_arm do
      url "https://github.com/jakobhviid/pwtune/releases/download/v@VERSION@/pwtune-aarch64-unknown-linux-musl.tar.gz"
      sha256 "@ARM_SHA@"
    end
  end

  def install
    bin.install "pwtune"
    generate_completions_from_executable(bin/"pwtune", "completions")
    (man1/"pwtune.1").write Utils.safe_popen_read(bin/"pwtune", "man")
  end

  def caveats
    "pwtune is Linux-only and needs PipeWire (pactl/paplay/parecord) at runtime."
  end

  test do
    assert_match "pwtune", shell_output("#{bin}/pwtune --help")
  end
end
