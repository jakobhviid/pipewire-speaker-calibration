class SpeakerEq < Formula
  desc "Measure any speaker with any mic and build a PipeWire EQ profile"
  homepage "https://github.com/jakobhviid/pipewire-speaker-calibration"
  version "@VERSION@"
  license "MIT"

  on_linux do
    on_intel do
      url "https://github.com/jakobhviid/pipewire-speaker-calibration/releases/download/v@VERSION@/speaker-eq-x86_64-unknown-linux-musl.tar.gz"
      sha256 "@X86_SHA@"
    end
    on_arm do
      url "https://github.com/jakobhviid/pipewire-speaker-calibration/releases/download/v@VERSION@/speaker-eq-aarch64-unknown-linux-musl.tar.gz"
      sha256 "@ARM_SHA@"
    end
  end

  def install
    bin.install "speaker-eq"
  end

  def caveats
    "speaker-eq is Linux-only and needs PipeWire (pactl/paplay/parecord) at runtime."
  end

  test do
    assert_match "speaker-eq", shell_output("#{bin}/speaker-eq --help")
  end
end
